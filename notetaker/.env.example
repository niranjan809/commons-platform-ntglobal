# Copy to notetaker/.env and fill in. All optional — the tool degrades gracefully.

# Enables the Claude MoM brain (summary + per-member task assignment).
# Without it, a local keyword summarizer is used instead.
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-sonnet-4-6). Cheaper: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# Enables Slack delivery with --send. Reuse the same bot token as the Commons app.
# Bot scopes needed: chat:write (channel post) and im:write (DM members).
SLACK_BOT_TOKEN=xoxb-...
