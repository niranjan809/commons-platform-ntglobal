# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Zoho Meeting (OAuth2)
# Get this from: https://api-console.zoho.com → your app → OAuth tokens
# Required scope: ZohoMeeting.meeting.CREATE
ZOHO_ACCESS_TOKEN=your-zoho-oauth-access-token
ZOHO_REFRESH_TOKEN=your-zoho-oauth-refresh-token
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret

# AI Notetaker (in-app: Notetaker panel → MoM → Slack)
# Minutes of Meeting are generated with Claude. Without this key the app falls
# back to a basic keyword summary.
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
# In-app transcription of uploaded recordings (any language → English).
# Set ONE of these; Groq has a free tier and uses whisper-large-v3.
# Without either, the panel still works if you paste a transcript.
GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# Server
PORT=3000
